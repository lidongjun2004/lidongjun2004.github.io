<section class="relative overflow-hidden py-20 sm:py-28">
  <!-- Soft warm gradient background -->
  <div class="absolute inset-0 bg-gradient-to-br from-blue-50 via-orange-50/30 to-purple-50/40"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(96,165,250,0.08),transparent_50%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_80%,rgba(167,139,250,0.08),transparent_50%)]"></div>

  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 text-center">
    <h1 class="text-4xl sm:text-5xl font-bold text-[var(--color-heading)] mb-4">
      同学你好，欢迎来到 <span class="bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">L.D.J 的私家工坊</span>
    </h1>
    <p class="text-lg sm:text-xl text-[var(--color-text-light)] max-w-2xl mx-auto leading-relaxed">
      积极乐观、活力无穷、永远攀登。
    </p>
  </div>
</section>
