---
import { SECTION_META, type Section } from '../lib/sections';

interface Props {
  title: string;
  description?: string;
  date: Date;
  section: Section;
  category: string[];
  tags: string[];
  slug: string;
}

const { title, description, date, section, category, tags, slug } = Astro.props;
const meta = SECTION_META[section];
const dateStr = date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
---

<article class="bg-[var(--color-card)] rounded-xl p-5 shadow-sm hover:shadow-md transition-all duration-200 hover:-translate-y-0.5 border border-[var(--color-border)]">
  <div class="flex items-center gap-2 mb-3 text-xs">
    <span
      class="inline-flex items-center px-2 py-0.5 rounded-full text-white font-medium"
      style={`background-color: ${meta.color}`}
    >
      {meta.label}
    </span>
    {category.length > 0 && (
      <span class="text-[var(--color-text-light)]">
        {category.join(' / ')}
      </span>
    )}
  </div>

  <a href={`/${slug}/`} class="block group">
    <h3 class="text-lg font-semibold text-[var(--color-heading)] mb-2 group-hover:opacity-75 transition-opacity">
      {title}
    </h3>
  </a>

  {description && (
    <p class="text-sm text-[var(--color-text-light)] mb-3 line-clamp-2">
      {description}
    </p>
  )}

  <div class="flex items-center justify-between">
    <time class="text-xs text-[var(--color-text-light)]" datetime={date.toISOString()}>
      {dateStr}
    </time>
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1">
        {tags.slice(0, 3).map((tag) => (
          <a
            href={`/tags/${tag}/`}
            class="text-xs px-2 py-0.5 rounded-full bg-gray-100 text-[var(--color-text-light)] hover:bg-gray-200 transition-colors"
          >
            #{tag}
          </a>
        ))}
      </div>
    )}
  </div>
</article>
