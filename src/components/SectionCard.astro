---
interface Props {
  slug: string;
  label: string;
  description: string;
  color: string;
  icon: string;
  folderCount: number;
  postCount: number;
  urlPrefix?: string;
}

const { slug, label, description, color, icon, folderCount, postCount, urlPrefix = '' } = Astro.props;

const parts: string[] = [];
if (folderCount > 0) parts.push(`${folderCount} ${folderCount === 1 ? 'folder' : 'folders'}`);
if (postCount > 0) parts.push(`${postCount} ${postCount === 1 ? 'post' : 'posts'}`);
const countText = parts.length > 0 ? parts.join(', ') : '0 posts';
---

<a
  href={`${urlPrefix}/${slug}/`}
  class="group block bg-[var(--color-card)] rounded-xl p-6 shadow-sm hover:shadow-md transition-all duration-200 hover:-translate-y-0.5 border border-[var(--color-border)]"
  style={`border-top: 3px solid ${color}`}
>
  <div class="text-2xl mb-3">{icon}</div>
  <h3 class="text-lg font-semibold text-[var(--color-heading)] mb-1 group-hover:opacity-80 transition-opacity">
    {label}
  </h3>
  <p class="text-sm text-[var(--color-text-light)] mb-3 line-clamp-2" set:html={description} />
  <span class="text-xs text-[var(--color-text-light)]">
    {countText}
  </span>
</a>
