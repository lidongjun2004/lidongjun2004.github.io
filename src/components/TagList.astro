---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

{tags.length > 0 && (
  <div class="flex flex-wrap gap-2">
    {tags.map((tag) => (
      <a
        href={`/tags/${tag}/`}
        class="inline-flex items-center px-3 py-1 rounded-full text-sm bg-gray-100 text-[var(--color-text-light)] hover:bg-gray-200 transition-colors"
      >
        #{tag}
      </a>
    ))}
  </div>
)}
