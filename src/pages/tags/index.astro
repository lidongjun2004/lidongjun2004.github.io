---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);

// Build tag -> count map
const tagCounts = new Map<string, number>();
for (const post of allPosts) {
  for (const tag of post.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}

const sortedTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
const maxCount = Math.max(...sortedTags.map(([, c]) => c), 1);
---

<BaseLayout title="Tags" description="Browse all tags">
  <Header slot="header" />

  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <h1 class="text-3xl font-bold text-[var(--color-heading)] mb-8">Tags</h1>

    {sortedTags.length === 0 ? (
      <p class="text-[var(--color-text-light)]">No tags yet.</p>
    ) : (
      <div class="flex flex-wrap gap-3">
        {sortedTags.map(([tag, count]) => {
          const scale = 0.85 + (count / maxCount) * 0.4;
          return (
            <a
              href={`/tags/${tag}/`}
              class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-[var(--color-card)] border border-[var(--color-border)] text-[var(--color-text)] hover:shadow-sm hover:-translate-y-0.5 transition-all duration-200"
              style={`font-size: ${scale}rem`}
            >
              <span>#{tag}</span>
              <span class="text-xs text-[var(--color-text-light)]">({count})</span>
            </a>
          );
        })}
      </div>
    )}
  </section>

  <Footer slot="footer" />
</BaseLayout>
