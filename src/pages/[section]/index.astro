---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FolderView from '../../components/FolderView.astro';
import { render } from 'astro:content';
import { SECTIONS, SECTION_META, type Section } from '../../lib/sections';
import { isIndex, listChildren, getPublicPosts } from '../../lib/content-utils';

export function getStaticPaths() {
  return SECTIONS.map((section) => ({ params: { section } }));
}

const { section } = Astro.params as { section: Section };
const meta = SECTION_META[section];

const allPosts = await getPublicPosts();

// Find this section's _index.md
const indexPost = allPosts.find((p) => p.id === `${section}/_index`);
let IndexContent: any = null;
if (indexPost) {
  const rendered = await render(indexPost);
  IndexContent = rendered.Content;
}

// List direct children
const { folders, docs } = listChildren(allPosts, section);
---

<BaseLayout title={meta.label} description={indexPost?.data.description ?? meta.description}>
  <Header slot="header" />

  <section
    class="py-12 sm:py-16 border-b border-[var(--color-border)]"
    style={`background: linear-gradient(135deg, ${meta.color}08, ${meta.color}03)`}
  >
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <span class="text-3xl mb-3 block">{meta.icon}</span>
      <h1 class="text-3xl sm:text-4xl font-bold text-[var(--color-heading)] mb-3">
        {meta.label}
      </h1>
      <p class="text-lg text-[var(--color-text-light)] max-w-2xl" set:html={meta.description} />
    </div>
  </section>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
    {/* Render _index.md content if it has a body */}
    {IndexContent && (
      <div class="prose mb-10">
        <IndexContent />
      </div>
    )}

    <FolderView folders={folders} docs={docs} />
  </div>

  <Footer slot="footer" />
</BaseLayout>
