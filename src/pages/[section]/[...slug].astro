---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import TagList from '../../components/TagList.astro';
import { getCollection, render } from 'astro:content';
import { SECTION_META } from '../../lib/sections';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { section: post.data.section, slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, date, updated, section, category, tags } = post.data;
const meta = SECTION_META[section];
const dateStr = date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
const updatedStr = updated?.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });

// Get prev/next posts in same section
const allPosts = await getCollection('posts', ({ data }) => data.section === section && !data.draft);
const sorted = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const idx = sorted.findIndex((p) => p.id === post.id);
const prev = idx < sorted.length - 1 ? sorted[idx + 1] : null;
const next = idx > 0 ? sorted[idx - 1] : null;
---

<BaseLayout title={title} description={description}>
  <Header slot="header" />

  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-10">
    <!-- Breadcrumb -->
    <nav class="text-sm text-[var(--color-text-light)] mb-6 flex items-center gap-1.5 flex-wrap">
      <a href="/" class="hover:text-[var(--color-heading)]">Home</a>
      <span>/</span>
      <a href={`/${section}/`} class="hover:text-[var(--color-heading)]" style={`color: ${meta.color}`}>
        {meta.label}
      </a>
      {category.map((cat) => (
        <>
          <span>/</span>
          <span>{cat}</span>
        </>
      ))}
    </nav>

    <!-- Title -->
    <h1 class="text-3xl sm:text-4xl font-bold text-[var(--color-heading)] mb-4 leading-tight">
      {title}
    </h1>

    <!-- Meta -->
    <div class="flex flex-wrap items-center gap-3 text-sm text-[var(--color-text-light)] mb-6">
      <time datetime={date.toISOString()}>{dateStr}</time>
      {updatedStr && (
        <span class="text-xs">(updated {updatedStr})</span>
      )}
    </div>

    <!-- Tags -->
    <div class="mb-8">
      <TagList tags={tags} />
    </div>

    <!-- Content -->
    <div class="prose">
      <Content />
    </div>

    <!-- Prev / Next -->
    <nav class="mt-16 pt-8 border-t border-[var(--color-border)] grid grid-cols-1 sm:grid-cols-2 gap-4">
      {prev && (
        <a
          href={`/${section}/${prev.id}/`}
          class="group block bg-[var(--color-card)] rounded-xl p-4 border border-[var(--color-border)] hover:shadow-sm transition-shadow"
        >
          <span class="text-xs text-[var(--color-text-light)]">Previous</span>
          <p class="text-sm font-medium text-[var(--color-heading)] group-hover:opacity-75 transition-opacity mt-1">
            {prev.data.title}
          </p>
        </a>
      )}
      {next && (
        <a
          href={`/${section}/${next.id}/`}
          class:list={["group block bg-[var(--color-card)] rounded-xl p-4 border border-[var(--color-border)] hover:shadow-sm transition-shadow text-right", !prev && "sm:col-start-2"]}
        >
          <span class="text-xs text-[var(--color-text-light)]">Next</span>
          <p class="text-sm font-medium text-[var(--color-heading)] group-hover:opacity-75 transition-opacity mt-1">
            {next.data.title}
          </p>
        </a>
      )}
    </nav>
  </article>

  <Footer slot="footer" />
</BaseLayout>
