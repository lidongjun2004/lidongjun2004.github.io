---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="About" description="About L.D.J">
  <Header slot="header" />

  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <div class="text-center mb-12">
      <!-- Avatar placeholder -->
      <div class="w-28 h-28 mx-auto mb-6 rounded-full bg-gradient-to-br from-blue-100 to-purple-100 flex items-center justify-center text-4xl shadow-sm">
        👋
      </div>
      <h1 class="text-3xl font-bold text-[var(--color-heading)] mb-2">李东骏</h1>
      <p class="text-lg text-[var(--color-text-light)]">L.D.J</p>
    </div>

    <div class="prose mx-auto">
      <h2>Hi there!</h2>
      <p>
        Welcome to my blog. Here I write about technology, career growth, academics,
        and the things I love. This is a space for learning, reflecting, and sharing.
      </p>

      <h2>What you'll find here</h2>
      <ul>
        <li><strong>Tech Stack</strong> — Languages, frameworks, and tools I work with</li>
        <li><strong>Career</strong> — Professional growth and reflections</li>
        <li><strong>Academics</strong> — Courses, research, and mathematical explorations</li>
        <li><strong>Love & Interests</strong> — Hobbies and passions</li>
        <li><strong>Plan & Think</strong> — Goals and forward-looking thoughts</li>
      </ul>

      <h2>Get in touch</h2>
      <p>
        Feel free to reach out via
        <a href="https://github.com/lidongjun2004">GitHub</a>.
      </p>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
